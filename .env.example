# ============================================================
# Linux-Codex-Webui Docker 环境配置示例
# 使用方式：cp .env.example .env 后按需修改
# ============================================================

# ---------- 基础 ----------

# Web 服务端口（容器内监听端口 + 宿主机映射端口）
WEBUI_PORT=5900

# 访问密码。留空则每次启动自动生成，
# 可通过 `docker compose logs webui` 在启动输出中查看
WEBUI_PASSWORD=

# 设为 true 完全禁用密码保护（仅建议在可信内网环境使用）
WEBUI_NO_PASSWORD=false

# ---------- 隧道 / 登录 ----------

# 是否启动 cloudflared 公网隧道。
# 需要构建镜像时开启 --build-arg INSTALL_CLOUDFLARED=true
# （或修改 docker-compose.yml 中的 build args）
WEBUI_TUNNEL=false

# 启动时是否自动执行 `codex login` 引导。
# 容器内推荐保持 false，改用以下任一方式提供凭据：
#   1. 挂载宿主机已登录的 ~/.codex 到容器 /data/codex（见 docker-compose.yml 注释）
#   2. 配置 OPENAI_API_KEY 后进入容器执行：
#      docker compose exec webui codex login --api-key "$OPENAI_API_KEY"
WEBUI_AUTO_LOGIN=false

# ---------- Codex 运行策略 ----------

# 沙箱模式：read-only | workspace-write | danger-full-access
# 注意：容器内 Linux 沙箱（landlock/seccomp）可能不可用，
# 若 codex 报沙箱相关错误，可改为 danger-full-access
# （容器本身已提供一层隔离）
CODEXUI_SANDBOX_MODE=workspace-write

# 审批策略：untrusted | on-failure | on-request | never
CODEXUI_APPROVAL_POLICY=on-request

# ---------- API 凭据（可选） ----------

# 使用 API Key 方式登录 Codex 时填写
OPENAI_API_KEY=

# 使用自建网关 / 代理时可配置（供容器内 codex 使用）
# OPENAI_BASE_URL=
# HTTP_PROXY=
# HTTPS_PROXY=

# ---------- 挂载路径 ----------

# 宿主机工作目录，挂载到容器 /workspace，
# 在 WebUI 中打开 /workspace 下的项目
WORKSPACE_DIR=./workspace
